@model IEnumerable<Game>


@{
    ViewData["Title"] = "Home Page";
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning" bis_skin_checked="1">
        <h4 class="alert-heading">no game founded</h4>
        <p class="mb-0">there are no games added yet</p>
    </div>
}
else
{
    <div class="row mt-4">
        @foreach (var game in Model)
        {
            <a class="col-lg-4 col-md-6 text-decoration-none overflow-hidden mb-3" asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
                <div class="card border-secondary mb-3">

                    <div class="card-body"
                         style="background-image: url('@($"{Filesetting.ImagePath}/{game.Cover}")');
                        background-size: cover;
                        background-position: center;
                        height: 400px;">

                        <div class="h-100">
                            <span class="badge bg-secondary">@game.categorey.Name</span>
                        </div>
                    </div>

                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <h5>@game.Name</h5>
                        <div>
                            @foreach (var item in game.Device)
                            {
                                <i class="@item.Device.Icon me-2 fs-4"></i>
                            }
                        </div>
                    </div>

                </div>
            </a>
        }
    </div>
}

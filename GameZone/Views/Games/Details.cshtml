@model Game
@{
    ViewData["Title"] = Model.Name;
}

<div class=" card border-success overflow-hidden rounded-4 mt-5">
    <div class="card-body p-0">
        <div class="row">
            <div class="col-md-8 d-flex flex-column justify-content-between px-4 py-4">
                <div>
                    <h1 class=" fw-bolder text-success"> @Model.Name</h1>
                    <span class="badge bg-info fs-5 "> @Model.categorey</span>
                    <p class="fs-5 mt-3">@Model.Description</p>
                </div>
                <div>
                    @foreach (var item in Model.Device)
                    {
                        <i class="@item.Device.Icon me-2 fs-4"></i>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <img src="@($"{Filesetting.ImagePath}/{Model.Cover}")" class="game-img w-100"/>
            </div>
        </div>
    </div>


</div>